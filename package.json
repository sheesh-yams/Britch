{
  "name": "britch-scaffold",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "if [ \"$NEXT_BUILD_ONLY\" = \"1\" ]; then next build --webpack; else NEXT_BUILD_ONLY=1 npx @opennextjs/cloudflare build; fi",
    "build:next": "next build --webpack",
    "build:worker": "npx @opennextjs/cloudflare build",
    "start": "next start",
    "preview": "npx wrangler dev",
    "deploy": "npm run build && npx wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "npx wrangler d1 migrations apply britch-db --local",
    "db:migrate:remote": "npx wrangler d1 migrations apply britch-db --remote",
    "seed:local": "npx wrangler d1 execute britch-db --local --file=./prisma/seed.sql",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "better-auth": "^1.6.14",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.1.11",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260610.1",
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.6",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "vitest": "^3.2.6",
    "wrangler": "^4.98.0"
  },
  "overrides": {
    "kysely": "0.28.17"
  }
}
