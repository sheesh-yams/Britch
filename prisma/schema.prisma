// ============================================================
// Britch — Prisma Schema
// Target: Cloudflare D1 (SQLite) via @prisma/adapter-d1
// Conventions:
//   - Money = integer CENTS (no Decimal)
//   - All other numerics = integer BASIS POINTS (10000 = 1.0×)
//   - CPM = cents per 1,000 reach
//   - Enums = String + TS union (D1/SQLite has no native enum)
//   - JSON = stored as text (Prisma Json maps cleanly)
// ============================================================

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "workerd"
  moduleFormat = "esm"
}

datasource db {
  provider = "sqlite"
}

// ════════════════════════════════════════════════════════════
// BETTER AUTH — User + Session tables (managed by better-auth)
// ════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Britch role flag — gates /admin routes
  // Validated as: "USER" | "ADMIN"
  role          String    @default("USER")

  // Better Auth relations
  sessions      Session[]
  accounts      Account[] @relation("BetterAuthAccounts")

  // Britch creator account (1:1 in MVP)
  creatorAccount CreatorAccount? @relation("OwnerUser")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation("BetterAuthAccounts", fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ════════════════════════════════════════════════════════════
// CREATOR-SCOPED PLANE
// All models below have accountId — enforced via getScopedDb()
// ════════════════════════════════════════════════════════════

// The creator's account — owns everything in the creator plane
model CreatorAccount {
  id          String   @id @default(cuid())
  ownerUserId String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  owner         User            @relation("OwnerUser", fields: [ownerUserId], references: [id], onDelete: Cascade)
  profile       CreatorProfile?
  socialAccounts SocialAccount[]
  deliverables  Deliverable[]
  bundles       Bundle[]
  addOns        AddOn[]
  workItems     WorkItem[]
  brands        Brand[]
  ratePages     RatePage[]
  proposals     Proposal[]
}

model CreatorProfile {
  id                String   @id @default(cuid())
  accountId         String   @unique
  displayName       String
  bio               String?
  avatarKey         String?  // R2 key
  // niches: JSON array of Niche slugs e.g. ["lifestyle","travel"]
  niches            Json     @default("[]")
  // availabilityStatus: "AVAILABLE" | "BOOKED" | "OFF"
  availabilityStatus String  @default("AVAILABLE")
  // branding: { logoKey?: string, accentColor?: string }
  branding          Json     @default("{}")
  location          String?
  website           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  account CreatorAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model SocialAccount {
  id                String   @id @default(cuid())
  accountId         String
  // platform: "INSTAGRAM" | "TIKTOK"
  platform          String
  handle            String
  followers         Int      @default(0)
  // engagementRateBps: 450 = 4.5%
  engagementRateBps Int      @default(0)
  // avgViews: drives pricing (reach, not followers)
  avgViews          Int      @default(0)
  // audience: { gender{}, ageBands{}, topCountries[] }
  audience          Json     @default("{}")
  // source: "SEEDED" | "SELF_REPORTED" | "VERIFIED" | "THIRD_PARTY"
  source            String   @default("SELF_REPORTED")
  // consentGrantedAt: explicit consent for connected accounts (GDPR/CCPA)
  consentGrantedAt  DateTime?
  disconnectedAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  account       CreatorAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  snapshots     AnalyticsSnapshot[]
  postSamples   PostSample[]

  @@unique([accountId, platform])
}

// Point-in-time analytics history (V1.1 trend charts — schema ready now)
model AnalyticsSnapshot {
  id                String   @id @default(cuid())
  socialAccountId   String
  accountId         String   // denormalized for scoped queries
  followers         Int
  engagementRateBps Int
  avgViews          Int
  audience          Json     @default("{}")
  source            String
  capturedAt        DateTime @default(now())

  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
}

// Last-20 post sample — feeds avgReach calculation
model PostSample {
  id              String    @id @default(cuid())
  socialAccountId String
  accountId       String    // denormalized
  // platform: "INSTAGRAM" | "TIKTOK"
  platform        String
  url             String?
  views           Int
  isPaid          Boolean   @default(false)
  postedAt        DateTime?
  createdAt       DateTime  @default(now())

  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
}

// The rate menu — one row per deliverable type per platform
model Deliverable {
  id                  String   @id @default(cuid())
  accountId           String
  // platform: "INSTAGRAM" | "TIKTOK"
  platform            String
  // type: "REEL" | "CAROUSEL" | "STORY" | "VIDEO" | "LIVE" | "SLIDE"
  type                String
  label               String?  // creator-facing display name override
  description         String?
  isActive            Boolean  @default(true)
  // reachUsed: snapshot of avgReach at compute time
  reachUsed           Int      @default(0)
  // suggestedRateCents: recomputed live from global plane
  suggestedRateCents  Int      @default(0)
  // finalRateCents: creator override; defaults to suggested
  finalRateCents      Int      @default(0)
  // floorCents: private negotiation floor
  floorCents          Int      @default(0)
  // stretchCents: upper end of range
  stretchCents        Int      @default(0)
  // breakdown: { avgReach, cpmCents, formatMultiplierBps, engAdjBps, weightedReach, baseCents }
  breakdown           Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  account CreatorAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, platform, type])
}

// Bundle — stacks deliverables with a discount
model Bundle {
  id              String   @id @default(cuid())
  accountId       String
  name            String
  // deliverableIds: JSON array of Deliverable ids
  deliverableIds  Json     @default("[]")
  // discountBps: e.g. 1500 = 15% off
  discountBps     Int      @default(0)
  // computedCents: pre-calculated bundle price
  computedCents   Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account CreatorAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

// Add-on services
model AddOn {
  id          String   @id @default(cuid())
  accountId   String
  // type: "USAGE_RIGHTS" | "WHITELISTING" | "RUSH" | "EXCLUSIVITY" | "OTHER"
  type        String
  label       String?
  description String?
  priceCents  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account CreatorAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

// Featured Work / Moodboard items
model WorkItem {
  id           String   @id @default(cuid())
  accountId    String
  // platform: "INSTAGRAM" | "TIKTOK"
  platform     String
  sourceUrl    String
  embedHtml    String?  // from oEmbed; nullable
  thumbnailKey String?  // R2 key — fetched-once, never hotlinked
  caption      String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account        CreatorAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  proposalItems  ProposalWorkItem[]
}

// Brand / client
model Brand {
  id            String   @id @default(cuid())
  accountId     String
  name          String
  contactName   String?
  contactEmail  String?
  logoKey       String?  // R2 key
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  account   CreatorAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  proposals Proposal[]
  ratePages RatePage[]
}

// Public rate page
model RatePage {
  id                String   @id @default(cuid())
  accountId         String
  token             String   @unique  // URL-safe 12-char token
  // status: "DRAFT" | "PUBLISHED"
  status            String   @default("DRAFT")
  // theme: JSON — { accentColor?, backgroundKey? }
  theme             Json     @default("{}")
  // preparedForBrandId: V1.1 personalization (field exists now)
  preparedForBrandId String?
  // frozenRates: JSON snapshot of rates at publish time
  frozenRates       Json     @default("{}")
  publishedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  account  CreatorAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  brand    Brand?         @relation(fields: [preparedForBrandId], references: [id])
  views    RatePageView[]
}

model RatePageView {
  id          String   @id @default(cuid())
  ratePageId  String
  accountId   String   // denormalized
  ip          String?
  userAgent   String?
  referrer    String?
  viewedAt    DateTime @default(now())

  ratePage RatePage @relation(fields: [ratePageId], references: [id], onDelete: Cascade)
}

// Proposal
model Proposal {
  id          String   @id @default(cuid())
  accountId   String
  brandId     String
  token       String   @unique  // URL-safe 12-char token
  version     Int      @default(1)
  // status: "DRAFT" | "SENT" | "VIEWED" | "CHANGES_NEEDED" | "APPROVED" | "LOST" | "EXPIRED"
  status      String   @default("DRAFT")
  title       String?
  // lineItems: frozen deliverables + add-ons at send time
  lineItems   Json     @default("[]")
  // milestones: payment schedule — bps or flat cents, must sum to 10000 bps
  milestones  Json     @default("[]")
  // totalCents: sum of lineItems at send time (frozen)
  totalCents  Int      @default(0)
  // signatureName + signatureIp + approvedAt: approval tracking
  signatureName     String?
  signatureIp       String?
  approvedAt        DateTime?
  approvedTotalCents Int?
  expiresAt         DateTime?
  notes             String?
  sentAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  account   CreatorAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  brand     Brand            @relation(fields: [brandId], references: [id])
  workItems ProposalWorkItem[]
  views     ProposalView[]
}

// Curated work-item subset per proposal
model ProposalWorkItem {
  id          String @id @default(cuid())
  proposalId  String
  workItemId  String
  order       Int    @default(0)

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@unique([proposalId, workItemId])
}

// Read receipts
model ProposalView {
  id          String   @id @default(cuid())
  proposalId  String
  accountId   String   // denormalized
  ip          String?
  userAgent   String?
  viewedAt    DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

// ════════════════════════════════════════════════════════════
// BRITCH-GOVERNED PRICING PLANE
// Global, admin-only-writable. Read by every creator's engine.
// No accountId — not scoped.
// ════════════════════════════════════════════════════════════

// Niche taxonomy
model Niche {
  id       String  @id @default(cuid())
  slug     String  @unique  // e.g. "lifestyle"
  label    String           // e.g. "Lifestyle"
  isActive Boolean @default(true)
  order    Int     @default(0)

  benchmarks CpmBenchmark[]
}

// CPM benchmarks — engine reads these
// cpmCents: cents per 1,000 reach (e.g. $12 CPM → 1200)
// nicheId NULL = generic fallback; populated = niche-adjusted
model CpmBenchmark {
  id            String   @id @default(cuid())
  // platform: "INSTAGRAM" | "TIKTOK"
  platform      String
  nicheId       String?  // NULL = generic MVP model
  // followerTier: "NANO" | "MICRO" | "MID" | "MACRO"
  followerTier  String
  cpmCents      Int      // e.g. 1200 = $12.00 CPM
  source        String?  // e.g. "CreatorIQ 2026 Benchmark Report"
  effectiveDate DateTime @default(now())
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  niche Niche? @relation(fields: [nicheId], references: [id])

  @@unique([platform, nicheId, followerTier])
}

// Format multipliers — scales base CPM rate by content format
// multiplierBps: 10000 = 1.0×, 8500 = 0.85×, 5000 = 0.5×, 12000 = 1.2×
model FormatMultiplier {
  id              String  @id @default(cuid())
  // platform: "INSTAGRAM" | "TIKTOK"
  platform        String
  // deliverableType: "REEL" | "CAROUSEL" | "STORY" | "VIDEO" | "LIVE" | "SLIDE"
  deliverableType String
  multiplierBps   Int     // basis points
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([platform, deliverableType])
}

// Engine parameters — singleton, versioned, admin-tunable
model EngineParams {
  id                    String   @id @default(cuid())
  version               Int      @default(1)
  isActive              Boolean  @default(true)  // only one active row
  label                 String?  // e.g. "v1 — launch defaults"
  // Weighting: price mostly on reach, followers as fallback
  reachWeightBps        Int      @default(8500)   // 85%
  followerWeightBps     Int      @default(1500)   // 15%
  // Engagement adjustment
  benchmarkEngagementBps Int     @default(300)    // 3.0% baseline
  engAdjMinBps          Int      @default(7000)   // floor multiplier 0.7×
  engAdjMaxBps          Int      @default(13000)  // ceiling multiplier 1.3×
  // Rounding + spread
  roundingCents         Int      @default(5000)   // round to nearest $50
  floorSpreadBps        Int      @default(2000)   // floor = 20% below target
  stretchSpreadBps      Int      @default(2000)   // stretch = 20% above target
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Seed creator — powers SeededProvider demo
model SeedCreator {
  id          String   @id @default(cuid())
  handle      String
  // platform: "INSTAGRAM" | "TIKTOK"
  platform    String
  displayName String
  // snapshot: full AnalyticsSnapshot JSON
  snapshot    Json
  // postSample: array of { views, isPaid, postedAt? }
  postSample  Json     @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([handle, platform])
}

// Pricing model version — rollback (V1.1, schema ready now)
model PricingModelVersion {
  id               String   @id @default(cuid())
  label            String
  paramsSnapshot   Json     // snapshot of EngineParams at publish
  benchmarkSnapshot Json    // snapshot of all active CpmBenchmark rows
  publishedAt      DateTime @default(now())
  publishedBy      String   // userId
}

// Provider config — admin selects active analytics source without deploy
model ProviderConfig {
  id                      String   @id @default(cuid())
  // activeAnalyticsProvider: "SEEDED" | "MANUAL" | "PHYLLO" | "HYPE_AUDITOR" | "DIRECT_PLATFORM"
  activeAnalyticsProvider String   @default("SEEDED")
  // oembedTokens: { instagram?: string } — oEmbed API tokens
  oembedTokens            Json     @default("{}")
  updatedAt               DateTime @updatedAt
  updatedBy               String?  // userId
}
